{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ZeroGPU",
  "colors": {
    "primary": "#22C55E",
    "light": "#4ADE80",
    "dark": "#16A34A"
  },
  "favicon": "/favicon.ico",
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": false
    },
    "examples": {
      "languages": ["curl", "python", "javascript", "rust", "go", "ruby"],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    },
    "mdx": {
      "server": "https://api.zerogpu.ai/v1"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "platform/dashboard"
            ]
          },
          {
            "group": "Models",
            "pages": [
              "platform/model-catalog",
              "models/ad-tech",
              "models/text-classification",
              "models/text-generation",
              "models/pii",
              "models/summarization"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/organizations-and-projects",
              "platform/authentication",
              "platform/api-keys",
              "platform/usage-analytics",
              "platform/logs",
              "platform/billing"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/nano-language-models",
              "concepts/distributed-inference",
              "concepts/geo-aware-routing"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "faq",
              "resources/ai-and-mcp"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/responses",
              "api-reference/endpoint/chat-completions"
            ]
          },
          {
            "group": "SDK Examples",
            "pages": [
              "sdks/python",
              "sdks/javascript",
              "sdks/rust",
              "sdks/go",
              "sdks/ruby"
            ]
          }
        ]
      },
      {
        "tab": "Cookbook",
        "groups": [
          {
            "group": "Cookbook",
            "pages": [
              "cookbook/index",
              "cookbook/demos",
              "cookbook/summarize-text",
              "cookbook/iab-classification",
              "cookbook/data-extraction",
              "cookbook/data-extraction-tutorial",
              "cookbook/batch-requests"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://zerogpu.ai",
          "icon": "globe"
        },
        {
          "anchor": "Platform",
          "href": "https://platform.zerogpu.ai/",
          "icon": "rocket"
        },
        {
          "anchor": "llms.txt",
          "href": "https://docs.zerogpu.ai/llms.txt",
          "icon": "sparkles"
        },
        {
          "anchor": "llms-full.txt",
          "href": "https://docs.zerogpu.ai/llms-full.txt",
          "icon": "brain"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/zerogpu-docs-logo-light.png",
    "dark": "/logo/zerogpu-docs-logo-dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "",
        "href": "https://zerogpu.ai",
        "icon": "globe"
      },
      {
        "label": "",
        "href": "https://github.com/zerogpu",
        "icon": "github"
      },
      {
        "label": "",
        "href": "https://discord.gg/Ad5KZvAyky",
        "icon": "discord"
      },
      {
        "label": "",
        "href": "https://x.com/ZeroGPU_AI",
        "icon": "x-twitter"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Platform",
      "href": "https://platform.zerogpu.ai/"
    }
  },
  "footer": {
    "socials": {
      "website": "https://zerogpu.ai",
      "github": "https://github.com/zerogpu"
    }
  }
}

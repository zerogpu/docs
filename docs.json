{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ZeroGPU",
  "colors": {
    "primary": "#22C55E",
    "light": "#4ADE80",
    "dark": "#16A34A"
  },
  "favicon": "/favicon.ico",
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": false
    },
    "params": {
      "expanded": "all"
    },
    "examples": {
      "languages": [
        "curl",
        "python",
        "javascript",
        "rust",
        "go",
        "ruby"
      ],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    },
    "mdx": {
      "server": "https://api.zerogpu.ai/v1"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "platform/dashboard",
              "api-reference/batch/index"
            ]
          },
          {
            "group": "Models",
            "pages": [
              "platform/model-catalog",
              "models/ad-tech",
              "models/text-classification",
              "models/text-generation",
              "models/pii",
              "models/summarization"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/organizations-and-projects",
              "platform/authentication",
              "platform/api-keys",
              "platform/usage-analytics",
              "platform/logs",
              "platform/billing"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/nano-language-models",
              "concepts/distributed-inference",
              "concepts/geo-aware-routing"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "faq",
              "resources/ai-and-mcp"
            ]
          }
        ]
      },
      {
        "tab": "Integrations",
        "groups": [
          {
            "group": "Integrations",
            "pages": [
              "integrations/index",
              "integrations/claude-code-plugin"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/responses",
              "api-reference/endpoint/chat-completions",
              {
                "group": "By model",
                "pages": [
                  "api-reference/models/index",
                  "models/deberta-v3-small",
                  "models/gliner-multi-pii-v1",
                  "models/gliner2-base-v1",
                  "models/lfm2-5-1-2b-instruct",
                  "models/lfm2-5-1-2b-thinking",
                  "models/llama-3-1-8b-instruct-fast",
                  "models/zlm-v1-followup-questions-edge",
                  "models/zlm-v1-iab-classify-edge",
                  "models/zlm-v1-iab-classify-edge-enriched"
                ]
              }
            ]
          },
          {
            "group": "Batch API",
            "pages": [
              "api-reference/batch/index",
              "api-reference/batch/getting-started",
              "api-reference/batch/upload-file",
              "api-reference/batch/list-files",
              "api-reference/batch/retrieve-file",
              "api-reference/batch/download-file",
              "api-reference/batch/delete-file",
              "api-reference/batch/files-api",
              "api-reference/batch/create-batch",
              "api-reference/batch/retrieve-batch",
              "api-reference/batch/list-batches",
              "api-reference/batch/cancel-batch",
              "api-reference/batch/batches-api",
              "api-reference/batch/jsonl-format",
              "api-reference/batch/supported-endpoints",
              "api-reference/batch/examples",
              "api-reference/batch/errors"
            ]
          },
          {
            "group": "SDK Examples",
            "pages": [
              "sdks/python",
              "sdks/javascript",
              "sdks/rust",
              "sdks/go",
              "sdks/ruby"
            ]
          }
        ]
      },
      {
        "tab": "Cookbook",
        "groups": [
          {
            "group": "General",
            "pages": [
              "cookbook/data-extraction-tutorial"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "cookbook/claude-code-csv-sanitizer"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://zerogpu.ai",
          "icon": "globe"
        },
        {
          "anchor": "Platform",
          "href": "https://platform.zerogpu.ai/",
          "icon": "rocket"
        },
        {
          "anchor": "llms.txt",
          "href": "https://docs.zerogpu.ai/llms.txt",
          "icon": "sparkles"
        },
        {
          "anchor": "llms-full.txt",
          "href": "https://docs.zerogpu.ai/llms-full.txt",
          "icon": "brain"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/zerogpu-docs-logo-light.png",

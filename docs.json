{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ZeroGPU",
  "colors": {
    "primary": "#22C55E",
    "light": "#4ADE80",
    "dark": "#16A34A"
  },
  "favicon": "/assets/logo/favicon.ico",
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": false
    },
    "params": {
      "expanded": "all"
    },
    "examples": {
      "languages": [
        "curl",
        "python",
        "javascript",
        "rust",
        "go",
        "ruby"
      ],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    },
    "mdx": {
      "server": "https://api.zerogpu.ai/v1"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "docs/how-zerogpu-works",
              "docs/quickstart"
            ]
          },
          {
            "group": "Models",
            "pages": [
              "docs/model-catalog",
              "docs/text-classification",
              "docs/text-generation",
              "docs/pii",
              "docs/summarization"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              {
                "group": "Batch & Files API",
                "pages": [
                  "docs/batch/index",
                  "docs/batch/getting-started",
                  "docs/batch/jsonl-format",
                  "docs/batch/files-api",
                  "docs/batch/batches-api",
                  "docs/batch/examples",
                  "docs/batch/errors"
                ]
              },
              "docs/production-patterns"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "docs/platform"
            ]
          }
        ]
      },
      {
        "tab": "Integrations",
        "groups": [
          {
            "group": "Integrations",
            "pages": [
              "integrations/index",
              "integrations/claude-code-plugin"
            ]
          },
          {
            "group": "Official SDKs",
            "pages": [
              "integrations/python",
              "integrations/javascript",
              "integrations/rust",
              "integrations/go",
              "integrations/ruby"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/responses",
              "api-reference/endpoint/chat-completions",
              {
                "group": "By model",
                "pages": [
                  "api-reference/models/index",
                  "models/deberta-v3-small",
                  "models/gliner-multi-pii-v1",
                  "models/gliner2-base-v1",
                  "models/lfm2-5-1-2b-instruct",
                  "models/lfm2-5-1-2b-thinking",
                  "models/llama-3-1-8b-instruct-fast",
                  "models/zlm-v1-followup-questions-edge",
                  "models/zlm-v1-iab-classify-edge",
                  "models/zlm-v1-iab-classify-edge-enriched"
                ]
              }
            ]
          },
          {
            "group": "Batch API",
            "pages": [
              "api-reference/batch/upload-file",
              "api-reference/batch/list-files",
              "api-reference/batch/retrieve-file",
              "api-reference/batch/download-file",
              "api-reference/batch/delete-file",
              "api-reference/batch/create-batch",
              "api-reference/batch/retrieve-batch",
              "api-reference/batch/list-batches",
              "api-reference/batch/cancel-batch",
              "api-reference/batch/supported-endpoints"
            ]
          }
        ]
      },
      {
        "tab": "Cookbook",
        "groups": [
          {
            "group": "General",
            "pages": [
              "cookbook/data-extraction-tutorial"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "cookbook/claude-code-csv-sanitizer"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://zerogpu.ai",
          "icon": "globe"
        },
        {
          "anchor": "Platform",
          "href": "https://platform.zerogpu.ai/",
          "icon": "rocket"
        },
        {
          "anchor": "llms.txt",
          "href": "https://docs.zerogpu.ai/llms.txt",
          "icon": "sparkles"
        },
        {
          "anchor": "llms-full.txt",
          "href": "https://docs.zerogpu.ai/llms-full.txt",
          "icon": "brain"
        }
      ]
    }
  },
  "logo": {
    "light": "/assets/logo/zerogpu-docs-logo-light.png",
    "dark": "/assets/logo/zerogpu-docs-logo-dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "",
        "href": "https://zerogpu.ai",
        "icon": "globe"
      },
      {
        "label": "",
        "href": "https://github.com/zerogpu",
        "icon": "github"
      },
      {
        "label": "",
        "href": "https://discord.gg/Ad5KZvAyky",
        "icon": "discord"
      },
      {
        "label": "",
        "href": "https://x.com/ZeroGPU_AI",
        "icon": "x-twitter"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Platform",
      "href": "https://platform.zerogpu.ai/"
    }
  },
  "redirects": [
    {
      "source": "/sdks/:slug",
      "destination": "/integrations/:slug"
    },
    {
      "source": "/platform/model-catalog",
      "destination": "/docs/model-catalog"
    },
    {
      "source": "/model-catalog",
      "destination": "/docs/model-catalog"
    },
    {
      "source": "/api-reference/batch/index",
      "destination": "/docs/batch"
    },
    {
      "source": "/api-reference/batch",
      "destination": "/docs/batch"
    },
    {
      "source": "/api-reference/batch/getting-started",
      "destination": "/docs/batch/getting-started"
    },
    {
      "source": "/api-reference/batch/jsonl-format",
      "destination": "/docs/batch/jsonl-format"
    },
    {
      "source": "/api-reference/batch/files-api",
      "destination": "/docs/batch/files-api"
    },
    {
      "source": "/api-reference/batch/batches-api",
      "destination": "/docs/batch/batches-api"
    },
    {
      "source": "/api-reference/batch/examples",
      "destination": "/docs/batch/examples"
    },
    {
      "source": "/api-reference/batch/errors",
      "destination": "/docs/batch/errors"
    },
    {
      "source": "/platform/dashboard",
      "destination": "/docs/platform#dashboard"
    },
    {
      "source": "/platform/organizations-and-projects",
      "destination": "/docs/platform#organizations-and-projects"
    },
    {
      "source": "/platform/api-keys",
      "destination": "/docs/platform#api-keys"
    },
    {
      "source": "/platform/authentication",
      "destination": "/docs/platform#authentication"
    },
    {
      "source": "/platform/usage-analytics",
      "destination": "/docs/platform#usage-and-logs"
    },
    {
      "source": "/platform/logs",
      "destination": "/docs/platform#usage-and-logs"
    },
    {
      "source": "/platform/billing",
      "destination": "/docs/platform#billing"
    },
    {
      "source": "/platform/security",
      "destination": "/docs/platform#api-keys"
    }
  ],
  "footer": {
    "socials": {
      "website": "https://zerogpu.ai",
      "github": "https://github.com/zerogpu"
    }
  }
}

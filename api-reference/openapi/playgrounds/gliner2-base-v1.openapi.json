                },
                "classification": {
                  "summary": "Text Classification",
                  "value": {
                    "model": "gliner2-base-v1",
                    "messages": [
                      {
                        "role": "user",
                        "content": "I absolutely love this product! The quality is outstanding and the customer service was incredibly helpful."
                      }
                    ],
                    "metadata": {
                      "schema": {
                        "sentiment": [
                          "positive",
